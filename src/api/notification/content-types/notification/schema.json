{
  "kind": "collectionType",
  "collectionName": "notifications",
  "info": {
    "singularName": "notification",
    "pluralName": "notifications",
    "displayName": "Notification",
    "description": "User notifications with 7 categories and priority levels"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "actor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "actorName": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["social", "engagement", "launchpad", "jobs", "messaging", "system", "growth"]
    },
    "priority": {
      "type": "enumeration",
      "enum": ["low", "medium", "high", "urgent"],
      "default": "low"
    },
    "action": {
      "type": "string"
    },
    "targetText": {
      "type": "string"
    },
    "targetUrl": {
      "type": "string"
    },
    "suffix": {
      "type": "string"
    },
    "isRead": {
      "type": "boolean",
      "default": false
    }
  }
}
