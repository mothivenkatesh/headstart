{
  "kind": "collectionType",
  "collectionName": "circles",
  "info": {
    "singularName": "circle",
    "pluralName": "circles",
    "displayName": "Circle",
    "description": "BFSI community groups/topics"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "icon": {
      "type": "string"
    },
    "memberCount": {
      "type": "integer",
      "default": 0
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post",
      "mappedBy": "circle"
    },
    "members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::circle-member.circle-member",
      "mappedBy": "circle"
    }
  }
}
